import numpy as np
import matplotlib.pyplot as plt
from scipy.integrate import simpson
from scipy.optimize import fsolve
from scipy import signal

tmax = 4.0
c_values = [0, 1, 10]

print("=" * 80)
print("К-2-07. Расчет движения автомобиля с нелинейным демпфером")
print("Метод: Рунге-Кутта 4-го порядка")
print("=" * 80)

print("\n1. РАСЧЕТ КОЭФФИЦИЕНТОВ ДЕМПФИРОВАНИЯ r0")
print("-" * 50)

A = np.array([
    [49, -18, -42],
    [-18, 16, 24],
    [-42, 24, 46]
], dtype=float)

b = np.array([-9040, 6880, 11520], dtype=float)

r0_values = np.linalg.solve(A, b)

print(f"   r0¹ = {r0_values[0]:.4f}")
print(f"   r0² = {r0_values[1]:.4f}")
print(f"   r0³ = {r0_values[2]:.4f}")

print("\n2. РАСЧЕТ ЖЕСТКОСТИ ПРУЖИНЫ K")
print("-" * 50)

x_int = np.linspace(0, 1, 1000)
f_int = np.sqrt(x_int) * np.sin(x_int)
I = simpson(f_int, x_int)
K = 1757.165 * I

print(f"   ∫₀¹ √x·sin(x) dx = {I:.8f}")
print(f"   K = 1757.165 * {I:.8f} = {K:.4f} Н/м")

print("\n3. РАСЧЕТ МАССЫ АВТОМОБИЛЯ M")
print("-" * 50)

def equation(x):
    return 2.2*x - 2**x

x_star = fsolve(equation, 0.7)[0]
M = 12.80212 * x_star

print(f"   Уравнение: 2.2x = 2^x")
print(f"   Наименьший корень x* = {x_star:.8f}")
print(f"   M = 12.80212 * {x_star:.8f} = {M:.6f} кг")


print("\n4. ФУНКЦИИ ДОРОГИ")
print("-" * 50)

def x0(t):
    return 2 * (1 - np.cos(7*t))

def dx0(t):
    return 14 * np.sin(7*t)

print(f"   x0(t) = 2(1 - cos(7t))")
print(f"   dx0/dt = 14·sin(7t)")


def F(t, Y, r0, c):
    x, v = Y
    relative_v = v - dx0(t)
    r = r0 * (1 + c * abs(relative_v))
    dxdt = v
    dvdt = (-K * (x - x0(t)) - r * relative_v) / M
    return np.array([dxdt, dvdt])


def RK4(h, r0, c):
    N = int(tmax / h)
    t = np.zeros(N + 1)
    Y = np.zeros((N + 1, 2))
    Y[0] = [0, 0]

    for n in range(N):
        k1 = F(t[n], Y[n], r0, c)
        k2 = F(t[n] + h/2, Y[n] + h*k1/2, r0, c)
        k3 = F(t[n] + h/2, Y[n] + h*k2/2, r0, c)
        k4 = F(t[n] + h, Y[n] + h*k3, r0, c)

        Y[n+1] = Y[n] + h * (k1 + 2*k2 + 2*k3 + k4) / 6
        t[n+1] = t[n] + h

    return t, Y[:, 0], Y[:, 1]


def runge_full_error(r0, c):
    """
    Оценка погрешности методом Рунге с тремя шагами
    """
    # Для жёстких систем (c=10) используем более крупные шаги
    if c >= 10:
        h_values = [0.04, 0.02, 0.01]
    else:
        h_values = [0.02, 0.01, 0.005]

    solutions = []
    for h in h_values:
        try:
            t, x, _ = RK4(h, r0, c)
            solutions.append((t, x))
        except Exception as e:
            print(f"   Ошибка при h={h}: {e}")
            return {'errors': [np.nan], 'p_order': np.nan, 'error_at_001': 1e-8}

    if len(solutions) < 2:
        return {'errors': [np.nan], 'p_order': np.nan, 'error_at_001': 1e-8}

    t_fine = solutions[-1][0]
    x_fine = solutions[-1][1]

    errors = []
    for i in range(len(solutions)-1):
        x_coarse = np.interp(t_fine, solutions[i][0], solutions[i][1])
        error = np.max(np.abs(x_coarse - x_fine))
        errors.append(error)

   
    if errors[0] == 0 or errors[1] == 0:
        p_order = 4.0
    else:
        p_order = np.log(errors[0]/errors[1]) / np.log(h_values[0]/h_values[1])

    
    if np.isnan(p_order) or np.isinf(p_order):
        p_order = 4.0

    
    h_work = 0.001
    try:
        error_at_h_work = errors[-1] * (h_work / h_values[-1])**p_order
        if np.isnan(error_at_h_work) or np.isinf(error_at_h_work):
            error_at_h_work = 1e-8
    except:
        error_at_h_work = 1e-8

    return {
        'errors': errors,
        'p_order': p_order,
        'error_at_001': error_at_h_work
    }


def sensitivity_analysis(r0, c, h=0.01):
    """
    Анализ чувствительности решения к погрешности параметров
    """
    
    global M, K
    M_orig = M
    K_orig = K

  
    t_base, x_base, _ = RK4(h, r0, c)
    max_base = np.max(x_base)

   
    M = M_orig * 1.05
    _, x_M_plus, _ = RK4(h, r0, c)
    max_M_plus = np.max(x_M_plus)

    M = M_orig * 0.95
    _, x_M_minus, _ = RK4(h, r0, c)
    max_M_minus = np.max(x_M_minus)

    
    M = M_orig 
    K = K_orig * 1.05
    _, x_K_plus, _ = RK4(h, r0, c)
    max_K_plus = np.max(x_K_plus)

    K = K_orig * 0.95
    _, x_K_minus, _ = RK4(h, r0, c)
    max_K_minus = np.max(x_K_minus)

    
    M = M_orig
    K = K_orig

    
    if max_base != 0:
        sens_M = ((max_M_plus - max_base) / max_base) / 0.05
        sens_K = ((max_K_plus - max_base) / max_base) / 0.05
    else:
        sens_M = 0
        sens_K = 0

    
    integral_M = np.trapz(np.abs(x_M_plus - x_base), t_base) / (np.trapz(np.abs(x_base), t_base) + 1e-10)
    integral_K = np.trapz(np.abs(x_K_plus - x_base), t_base) / (np.trapz(np.abs(x_base), t_base) + 1e-10)

    
    delta_M_calc = 0.01  # 1%
    delta_K_calc = 0.005  # 0.5%
    error_M_calc = abs(sens_M) * delta_M_calc * max_base
    error_K_calc = abs(sens_K) * delta_K_calc * max_base

    return {
        'sens_M': sens_M,
        'sens_K': sens_K,
        'error_M_calc': error_M_calc,
        'error_K_calc': error_K_calc,
        'integral_M': integral_M,
        'integral_K': integral_K,
        'x_M_plus': x_M_plus,
        'x_M_minus': x_M_minus,
        'x_K_plus': x_K_plus,
        'x_K_minus': x_K_minus,
        't': t_base,
        'x_base': x_base,
        'max_base': max_base
    }


