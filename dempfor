print("=" * 80)

results = []
sensitivity_results = []

for i in range(3):
    r0 = r0_values[i]
    c = c_values[i]

    print(f"\n{'='*50}")
    print(f"ДЕМПФЕР {i+1}: r0 = {r0:.4f}, c = {c}")
    print(f"{'='*50}")

    
    t, x, v = RK4(0.001, r0, c)

    
    x_max = np.max(x)
    x_min = np.min(x)
    amplitude = x_max - x_min
    rms = np.sqrt(np.mean(x**2))

    
    envelope = np.abs(signal.hilbert(x))
    threshold = 0.05 * np.max(envelope)
    start_idx = int(0.5 / 0.001)
    settle_idx = np.where(envelope[start_idx:] < threshold)[0]
    settle_time = t[start_idx + settle_idx[0]] if len(settle_idx) > 0 else tmax

    
    a = np.gradient(v, t)
    a_max = np.max(np.abs(a))

    
    energy = np.trapz(v**2, t)

    
    error_analysis = runge_full_error(r0, c)

    
    sens = sensitivity_analysis(r0, c)
    sensitivity_results.append(sens)

    
    results.append({
        'demper': i+1,
        'r0': r0,
        'c': c,
        'x_max': x_max,
        'x_min': x_min,
        'amplitude': amplitude,
        'rms': rms,
        'settle_time': settle_time,
        'a_max': a_max,
        'energy': energy,
        'error_h001': error_analysis['error_at_001'],
        'p_order': error_analysis['p_order'],
        'sens_M': sens['sens_M'],
        'sens_K': sens['sens_K'],
        'error_M_calc': sens['error_M_calc'],
        'error_K_calc': sens['error_K_calc']
    })

    
    print(f"\n  ПОКАЗАТЕЛИ КАЧЕСТВА:")
    print(f"    x_max = {x_max:.4f} м")
    print(f"    x_min = {x_min:.4f} м")
    print(f"    Размах = {amplitude:.4f} м")
    print(f"    СКО = {rms:.4f} м")
    print(f"    Время затухания = {settle_time:.2f} с")
    print(f"    a_max = {a_max:.2f} м/с²")
    print(f"    Энергия = {energy:.4f}")
    print(f"\n  ПОГРЕШНОСТЬ МЕТОДА:")
    print(f"    Оцененный порядок точности: p = {error_analysis['p_order']:.2f}")
    print(f"    Погрешность при h=0.001: {error_analysis['error_at_001']:.2e} м")
    print(f"\n  ЧУВСТВИТЕЛЬНОСТЬ:")
    print(f"    Коэфф. чувствительности к M: {sens['sens_M']:.3f}")
    print(f"    Коэфф. чувствительности к K: {sens['sens_K']:.3f}")


